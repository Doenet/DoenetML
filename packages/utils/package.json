{
    "name": "@doenet/utils",
    "type": "module",
    "description": "Common DoenetML utility functions",
    "version": "1.0.0",
    "license": "AGPL-3.0-or-later",
    "homepage": "https://github.com/Doenet/DoenetML#readme",
    "private": false,
    "repository": "github:Doenet/DoenetML",
    "files": [
        "/dist"
    ],
    "exports": {
        ".": {
            "import": "./dist/index.js"
        }
    },
    "scripts": {
        "dev": "vite",
        "watch": "vite build --watch",
        "test": "vitest",
        "build": "wireit"
    },
    "wireit": {
        "build": {
            "command": "vite build",
            "files": [
                "src/**/*.ts",
                "src/**/*.js",
                "vite.config.ts",
                "tsconfig.json"
            ],
            "output": [
                "dist/**/*.js",
                "dist/**/*.d.ts",
                "dist/**/*.json"
            ],
            "dependencies": [
                "../parser:build"
            ]
        }
    },
    "dependencies": {
        "color-name": "^1.1.4",
        "nearest-color": "^0.4.4"
    },
    "devDependencies": {
        "@types/color-name": "^2.0.0",
        "@types/nearest-color": "^0.4.1"
    }
}
