{
    "extends": "../../tsconfig.build.json",
    "compilerOptions": {
        "outDir": "./dist/",
        "rootDir": "./src",
        "types": ["vite/client"]
    },
    "include": ["./**/*.ts", "./**/*.d.ts"],
