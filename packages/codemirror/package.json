{
    "name": "@doenet/codemirror",
    "type": "module",
    "description": "CodeMirror component for DoenetML",
    "version": "*",
    "license": "AGPL-3.0-or-later",
    "homepage": "https://github.com/Doenet/DoenetML#readme",
    "private": true,
    "repository": "github:Doenet/DoenetML",
    "files": [
        "/dist"
    ],
    "exports": {
        ".": {
            "import": "./dist/index.js"
        },
        "./index.css": {
            "import": "./dist/index.css"
        },
        "./*json": {
            "import": "./dist/generated/*.json"
        }
    },
    "scripts": {
        "dev": "vite",
        "watch": "vite build --watch",
        "test": "echo \"No tests \"",
        "test-cypress": "cypress open --component",
        "test-cypress-all": "cypress run --component -b 'chrome' --config video=false --headless",
        "build": "wireit"
    },
    "wireit": {
        "build": {
            "command": "vite build",
            "files": [
                "src/**/*.ts",
                "src/**/*.css",
                "tsconfig.json",
                "vite.config.ts",
                "src/**/*.tsx"
            ],
            "output": [
                "dist/**/*.js",
                "dist/**/*.css",
                "dist/**/*.d.ts",
                "dist/**/*.json"
            ],
            "dependencies": [
                "../parser:build",
                "../lsp:build"
            ]
        }
    },
    "dependencies": {},
    "devDependencies": {}
}
