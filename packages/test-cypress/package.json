{
    "name": "@doenet/test-cypress",
    "type": "module",
    "description": "Endpoint to run cypress DoenetML tests",
    "version": "*",
    "license": "AGPL-3.0-or-later",
    "homepage": "https://github.com/Doenet/DoenetML#readme",
    "private": true,
    "repository": "github:Doenet/DoenetML",
    "files": [
        "/dist"
    ],
    "scripts": {
        "dev": "vite",
        "build": "wireit",
        "test": "echo \"No tests \"",
        "preview": "vite preview",
        "test-cypress": "cypress open",
        "test-cypress-all": "cypress run -b 'chrome' --config video=false --headless",
        "test-cypress-fast-fail": "cypress run -b 'chrome' --headless --config video=false,retries=0,defaultCommandTimeout=8000",
        "test-cypress-parallel": "cypress-parallel -s test-cypress-all -t 4 -d cypress/e2e -n ../../node_modules/cypress-multi-reporters",
        "test:group1": "cypress run -b 'chrome' --config video=false --headless --expose grepTags='@group1',grepFilterSpecs=true,grepOmitFiltered=true",
        "test:group2": "cypress run -b 'chrome' --config video=false --headless --expose grepTags='@group2',grepFilterSpecs=true,grepOmitFiltered=true",
        "test:group3": "cypress run -b 'chrome' --config video=false --headless --expose grepTags='@group3',grepFilterSpecs=true,grepOmitFiltered=true",
        "test:group4": "cypress run -b 'chrome' --config video=false --headless --expose grepTags='@group4',grepFilterSpecs=true,grepOmitFiltered=true",
        "test:group5": "cypress run -b 'chrome' --config video=false --headless --expose grepTags='@group5',grepFilterSpecs=true,grepOmitFiltered=true",
        "test:mistagged": "cypress run -b 'chrome' --config video=false --headless --expose grepTags='-@group1+-@group2+-@group3+-@group4+-@group5',grepFilterSpecs=true,grepOmitFiltered=true",
        "test:prefigure-live-accessibility": "cypress open --env RUN_LIVE_PREFIGURE_ACCESSIBILITY=1 --config specPattern=cypress/e2e/prefigure/prefigureLiveAccessibility.cy.js"
    },
    "wireit": {
        "build": {
            "command": "vite build",
            "files": [
                "index.html",
                "public/**/*",
                "src/**/*.ts",
                "src/**/*.tsx",
                "src/**/*.jsx",
                "tsconfig.json",
                "vite.config.ts"
            ],
            "output": [
                "dist/**"
            ],
            "dependencies": [
                "../doenetml-prototype:build",
                "../doenetml:build",
                "../prefigure:build",
                "../ui-components:build"
            ]
        }
    },
    "peerDependencies": {
        "react": "^19.2.3",
        "react-dom": "^19.2.3"
    },
    "dependencies": {
        "@doenet/utils": "^*",
        "vite": "^*"
    },
    "devDependencies": {
        "cypress-vite": "^1.6.0"
    }
}
