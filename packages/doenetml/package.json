{
    "name": "@doenet/doenetml",
    "type": "module",
    "description": "Semantic markup for building interactive web activities",
    "version": "0.7.18",
    "license": "AGPL-3.0-or-later",
    "homepage": "https://github.com/Doenet/DoenetML#readme",
    "private": true,
    "repository": {
        "type": "git",
        "url": "git+https://github.com/Doenet/DoenetML.git"
    },
    "files": [
        "/dist"
    ],
    "exports": {
        ".": {
            "import": "./dist/index.js",
            "require": "./dist/index.js"
        },
        "./*": {
            "import": "./dist/*",
            "require": "./dist/*"
        }
    },
    "scripts": {
        "dev": "vite",
        "build": "wireit",
        "build:dev": "wireit",
        "preview": "vite preview",
        "test": "vitest",
        "test-cypress": "cypress open --component",
        "test-cypress-all": "cypress run --component -b 'chrome' --config video=false --headless",
        "publish": "npm run build && cd dist && npm publish"
    },
    "wireit": {
        "build:dev": {
            "command": "vite build --mode development --outDir dist-dev",
            "files": [
                "src/**/*.html",
                "src/**/*.css"
            ],
            "output": [
                "dist-dev/**/*.js",
                "dist-dev/**/*.map",
                "dist-dev/**/*.css",
                "dist-dev/**/*.d.ts",
                "dist-dev/**/*.json"
            ],
            "dependencies": [
                "build"
            ]
        },
        "build": {
            "command": "vite build",
            "files": [
                "src/**/*.ts",
                "src/**/*.tsx",
                "src/**/*.js",
                "src/**/*.jsx",
                "src/**/*.css",
                "tsconfig.json",
                "vite.config.ts"
            ],
            "output": [
                "dist/**/*.js",
                "dist/**/*.map",
                "dist/**/*.d.ts",
                "dist/**/*.css",
                "dist/**/*.json",
                "dist/fonts/**/*"
            ],
            "dependencies": [
                "../doenetml-worker:build",
                "../codemirror:build",
                "../ui-components:build",
                "../utils:build",
                "../virtual-keyboard:build",
                "../parser:build",
                "../prefigure:build",
                "../lsp-tools:build"
            ]
        }
    },
    "peerDependencies": {
        "react": "^19.2.3",
        "react-dom": "^19.2.3"
    },
    "dependencies": {
        "@doenet/lsp-tools": "*",
        "@doenet/static-assets": "*",
        "dompurify": "^3.3.0"
    },
    "prettier": {
        "tabWidth": 4
    }
}
