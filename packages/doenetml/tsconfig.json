{
    "extends": "../../tsconfig.build.json",
    "compilerOptions": {
        "outDir": "./dist/",
        "rootDir": "./src",
        "lib": ["ES2021.String", "WebWorker", "DOM"]
    },
    "include": [
        "./**/*.ts",
        "./**/*.tsx",
        "./**/*.js",
        "./**/*.jsx",
        "./**/*.d.ts"
    ],
    "exclude": [
        "vite.config.ts",
        "cypress.config.ts",
        "test/cypress/**",
        "node_modules",
        "runner-results",
        ".wireit",
        "**/dist/**/*",
        "./dev"
    ],
    "references": []
}
