{
    "name": "@doenet/standalone",
    "type": "module",
    "description": "Standalone renderer for DoenetML suitable for being included in a web page",
    "version": "0.7.22",
    "license": "AGPL-3.0-or-later",
    "homepage": "https://github.com/Doenet/DoenetML#readme",
    "private": true,
    "repository": {
        "type": "git",
        "url": "git+https://github.com/Doenet/DoenetML.git"
    },
    "files": [
        "/dist"
    ],
    "exports": {
        ".": {
            "import": "./dist/doenet-standalone.js"
        },
        "./*": {
            "import": "./dist/*"
        }
    },
    "scripts": {
        "dev": "vite",
        "build": "wireit",
        "test": "echo \"No tests \"",
        "preview": "vite preview",
        "publish": "npm run build && node ../../.github/scripts/npm-publish-with-retry.mjs dist"
    },
    "wireit": {
        "build": {
            "command": "vite -c vite.config-coordinator.ts build",
            "files": [
                "src/coordinator.ts",
                "../doenetml-iframe/src/shared-core-pool.ts",
                "vite.config-coordinator.ts",
                "tsconfig.json"
            ],
            "output": [
                "dist/coordinator.js",
                "dist/coordinator.js.map"
            ],
            "dependencies": [
                "build:main"
            ]
        },
        "build:main": {
            "command": "vite build",
            "files": [
                "src/**/*.ts",
                "src/**/*.tsx",
                "tsconfig.json",
                "vite.config.ts"
            ],
            "output": [
                "dist/**/*.js",
                "!dist/coordinator.js",
                "dist/**/*.map",
                "!dist/coordinator.js.map",
                "dist/**/*.d.ts",
                "dist/**/*.json",
                "dist/**/*.css",
                "dist/fonts/**/*"
            ],
            "dependencies": [
                "../doenetml:build"
            ]
        }
    },
    "peerDependencies": {},
    "dependencies": {},
    "devDependencies": {}
}
